# =====================================================================
# WearWise — environment variables
# Copy this file to .env.local for local dev. In production (Vercel),
# set these in Project Settings -> Environment Variables instead.
# NEVER commit real values. NEVER prefix a secret with NEXT_PUBLIC_.
# =====================================================================

# --- Supabase (required) ---
# From Supabase -> Project Settings -> API.
# The anon key is safe for the browser; RLS protects all data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Public site URL (required) ---
# Used for magic-link auth redirects. Must match the deployed origin.
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app   (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- OpenAI (required for auto-tagging + outfit drafts) ---
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_ (that exposes it to the browser).
OPENAI_API_KEY=sk-...your-openai-key...

# --- Password login flag (OPTIONAL, dev only) ---
# Magic-link email is the default and only login method in the closed beta.
# Set to "true" ONLY in local dev if you want the email+password fallback
# (and the "Create account" button). Leave UNSET / "false" in production.
# NEXT_PUBLIC_ENABLE_PASSWORD_LOGIN=true

# --- Service role key (REQUIRED for Daily Drop preparation) ---
# SERVER-ONLY. Bypasses RLS, so it must NEVER reach the browser and must NEVER
# be prefixed with NEXT_PUBLIC_. Used by the scheduled cron route AND the manual
# prepare route to write daily_recommendations on the server's behalf.
# Set this BEFORE applying migration 0010 (after 0010, prepared inserts are
# server-only, so prepare needs this key).
SUPABASE_SERVICE_ROLE_KEY=server-only-do-not-expose

# --- Cron secret (REQUIRED for scheduled Daily Drop preparation) ---
# Protects /api/cron/daily-drop/prepare. Vercel Cron sends it automatically as
# `Authorization: Bearer <CRON_SECRET>` when set in the project. Use a long
# random string. If unset, the cron route returns 500 (safe: never runs
# unprotected). This route only PREPARES drops — it sends no notifications.
CRON_SECRET=replace-with-a-long-random-secret

# --- Analytics (OPTIONAL, PostHog) ---
# Lightweight product analytics for the closed beta. Loaded via the PostHog web
# snippet (no npm dependency). If the key is unset, analytics stays fully off and
# every track() call is a safe no-op. Only non-sensitive properties are sent
# (counts, categories, booleans, status strings) — never wardrobe images, paths,
# notes, names, or email. Analytics is off in development unless
# NEXT_PUBLIC_ANALYTICS_DEBUG=true.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_ANALYTICS_DEBUG=true

# --- Weather ---
# No env var needed. Weather context on Today + Style Me uses Open-Meteo, a free
# API with no key or signup. Only the user's city (then lat/lon) is sent to the
# provider; wardrobe data is never shared. If a city can't be resolved, weather
# simply shows as "unavailable".
